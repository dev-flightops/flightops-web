# Copy to .env.local and fill in. Three modes for backend connection:

# --- Mode A: pointing at Marc's local Docker via LAN IP (same network) ---
# NEXT_PUBLIC_API_URL=http://192.168.1.42:8000

# --- Mode B: pointing at Marc's Cloudflare tunnel (remote collaboration) ---
# NEXT_PUBLIC_API_URL=https://shy-mountain-xxxx.trycloudflare.com

# --- Mode C: pointing at local Docker (Marc + Greg on same machine) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Mode D: pointing at Render staging (independent work, always-on) ---
# NEXT_PUBLIC_API_URL=https://flightops-gateway-staging.onrender.com

# Auth.js v5 — signs the session JWT. Generate: openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Optional: only needed if behind a reverse proxy that strips host header
# AUTH_URL=http://localhost:3000
